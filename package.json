{
    "name": "zzz-search-overlay",
    "version": "1.0.0",
    "description": "Overlay search tool for Zenless Zone Zero",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
    },
    "build": {
        "appId": "com.zzz.search-overlay",
        "productName": "ZZZ Search Overlay",
        "win": {
            "target": "nsis",
            "icon": "build/icon.ico",
            "sign": false
        }
    },
    "devDependencies": {
        "cross-env": "^7.0.0",
        "electron": "^33.0.0",
        "electron-builder": "^25.0.0"
    },
    "dependencies": {
        "dotenv": "^17.3.1"
    }
}
